# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEFAULT_TENANT_DOMAIN=localhost:3000
DEFAULT_TENANT_SLUG=default

# Database
DATABASE_URL=postgresql://apv:apv@localhost:5432/apv?schema=public

# Redis (cache, rate limit, BullMQ)
REDIS_URL=redis://localhost:6379

# Object storage (Timeweb / Yandex S3-compatible) — заглушки до продакшена
S3_ENDPOINT=
S3_REGION=ru-1
S3_BUCKET_PUBLIC=
S3_BUCKET_PRIVATE=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# CRM / comms (заглушки)
AMOCRM_BASE_URL=
AMOCRM_ACCESS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
YANDEX_METRICA_ID=

# GigaChat (AI)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# JWT admin (минимум 32 символа в проде)
JWT_SECRET=dev-change-me-use-openssl-rand-base64-32
